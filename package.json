{
  "name": "@nomosmartcare/aws-sigv4-auth-cassandra-plugin",
  "version": "1.0.0",
  "description": "A sigv4 authentication plugin for open-source Datastax NodeJS Driver for Apache Cassandra",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "tsx node_modules/.bin/mocha 'test/unit/**/*.ts' -R spec -t 5000",
    "build-jsdocs": "jsdoc -c ./jsdoc-config.json"
  },
  "keywords": [
    "cassandra",
    "cql",
    "sigv4",
    "connection",
    "driver",
    "aws"
  ],
  "author": {
    "name": "Nomo Smart Care",
    "email": "",
    "url": "https://nomosmartcare.com/"
  },
  "homepage": "https://github.com/watch-nomo/aws-sigv4-auth-cassandra-nodejs-driver-plugin",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/watch-nomo/aws-sigv4-auth-cassandra-nodejs-driver-plugin"
  },
  "bugs": {
    "url": "https://github.com/watch-nomo/aws-sigv4-auth-cassandra-nodejs-driver-plugin/issues",
    "mail": ""
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "devDependencies": {
    "@smithy/types": "^4.14.0",
    "@types/chai": "^5.2.3",
    "@types/node": "^25.5.2",
    "chai": "^6.2.2",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1025.0",
    "cassandra-driver": "^4.8.0"
  }
}
